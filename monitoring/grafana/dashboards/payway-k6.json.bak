{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.85 },
              { "color": "red", "value": 0.95 }
            ]
          },
          "unit": "percentunit",
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Check Pass Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(k6_checks_total{check!~'.*fail.*'}[1m])) / sum(rate(k6_checks_total[1m]))",
          "legendFormat": "pass rate",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.10 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "HTTP Error Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(k6_http_req_failed_total[1m])) / sum(rate(k6_http_reqs_total[1m]))",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "p95 Response Time",
      "type": "stat",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_duration_bucket[1m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Active VUs",
      "type": "stat",
      "targets": [
        {
          "expr": "k6_vus",
          "legendFormat": "VUs",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Requests / sec",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(k6_http_reqs_total[30s]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Response Times",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "HTTP Request Duration Percentiles",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(k6_http_req_duration_bucket[30s])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_duration_bucket[30s])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(k6_http_req_duration_bucket[30s])) by (le))", "legendFormat": "p99", "refId": "C" }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "title": "Duration by URL",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_duration_bucket[30s])) by (le, url))",
          "legendFormat": "p95 {{ url }}",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Throughput & Errors",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 20,
      "title": "Requests per Second",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(k6_http_reqs_total[30s]))", "legendFormat": "total req/s", "refId": "A" },
        { "expr": "sum(rate(k6_http_req_failed_total[30s]))", "legendFormat": "failed req/s", "refId": "B" }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 21,
      "title": "Check Pass Rate Over Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(k6_checks_total{check!~'.*fail.*'}[30s])) / sum(rate(k6_checks_total[30s]))",
          "legendFormat": "pass rate",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Virtual Users & Iterations",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 30,
      "title": "Virtual Users",
      "type": "timeseries",
      "targets": [
        { "expr": "k6_vus", "legendFormat": "active VUs", "refId": "A" },
        { "expr": "k6_vus_max", "legendFormat": "max VUs", "refId": "B" }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 31,
      "title": "Iterations per Second",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(k6_iterations_total[30s]))", "legendFormat": "iterations/s", "refId": "A" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "title": "HTTP Phases (breakdown)",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 33 },
      "id": 40,
      "title": "Request Phase Breakdown (p95) — connect / waiting / receiving",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_connecting_bucket[30s])) by (le))", "legendFormat": "connecting", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_waiting_bucket[30s])) by (le))",    "legendFormat": "waiting (TTFB)", "refId": "B" },
        { "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_receiving_bucket[30s])) by (le))", "legendFormat": "receiving", "refId": "C" },
        { "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_sending_bucket[30s])) by (le))",   "legendFormat": "sending", "refId": "D" }
      ]
    }

  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["k6", "payway", "load-test"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "PayWay — k6 Load Tests",
  "uid": "payway-k6-dashboard",
  "version": 1
}
